---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Liên hệ | Vet AI Clinic" description="Liên hệ với Vet AI để triển khai website phòng khám thú y AI-built và host miễn phí trên Cloudflare.">
  <section>
    <p class="badge">Liên hệ</p>
    <h1>Liên hệ với Vet AI Clinic</h1>
    <p class="section-sub">Gửi yêu cầu, đặt lịch tư vấn giải pháp website phòng khám thú y AI-built và triển khai Cloudflare Pages.</p>
    <div class="grid-2">
      <div class="card feature">
        <h2>Thông tin liên hệ</h2>
        <p>Email: <a href="mailto:hello@vetai.example">hello@vetai.example</a></p>
        <p>Phone: <strong>0900 123 456</strong></p>
        <p>Địa chỉ: 123 Đường Thú Y, Quận 1, TP. Hồ Chí Minh</p>
      </div>
      <div class="card feature">
        <h2>Yêu cầu nhanh</h2>
        <p>Thích hợp cho:</p>
        <ul class="info-list">
          <li>Phòng khám mới cần website giới thiệu</li>
          <li>Dịch vụ chăm sóc thú cưng muốn quảng bá trực tuyến</li>
          <li>Khách hàng cần website tốc độ cao, an toàn và dễ mở rộng</li>
        </ul>
      </div>
    </div>
    <div class="card">
      <h3>Gửi yêu cầu của bạn</h3>
      <form action="https://formspree.io/f/mvzvdyag" method="POST">
        <div class="form-group">
          <label for="name">Họ tên</label>
          <input type="text" id="name" name="name" required>
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required>
        </div>
        <div class="form-group">
          <label for="phone">Số điện thoại</label>
          <input type="tel" id="phone" name="phone" required>
        </div>
        <div class="form-group">
          <label for="message">Nội dung yêu cầu</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <button type="submit" class="button button-primary">Gửi yêu cầu</button>
      </form>
      <p class="source-note">Form được gửi qua Formspree. Thay 'your-form-id' bằng ID thực từ Formspree.</p>
    </div>
  </section>
</BaseLayout>
