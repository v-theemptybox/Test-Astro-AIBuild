{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"jsx": "preserve",
		"jsxImportSource": "react",
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"types": [
			"astro/client"
		]
	},
	"include": [
		"src/**/*",
		"astro.config.mjs",
		"./worker-configuration.d.ts"
	]
}